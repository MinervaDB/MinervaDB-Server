<?xml version="1.0"?>
<!-- MinervaDB Server: 00-default-profile.xml - Default user query profile -->
<clickhouse>
    <profiles>
        <default>
            <!-- Memory limits -->
            <max_memory_usage>10737418240</max_memory_usage>
            <max_memory_usage_for_user>21474836480</max_memory_usage_for_user>
            <max_memory_usage_for_all_queries>85899345920</max_memory_usage_for_all_queries>

            <!-- Thread limits -->
            <max_threads>8</max_threads>
            <max_insert_threads>4</max_insert_threads>

            <!-- Execution limits -->
            <max_execution_time>300</max_execution_time>
            <timeout_before_checking_execution_speed>5</timeout_before_checking_execution_speed>
            <min_execution_speed>1000000</min_execution_speed>
            <min_execution_speed_bytes>0</min_execution_speed_bytes>

            <!-- Result limits -->
            <max_result_rows>0</max_result_rows>
            <max_result_bytes>0</max_result_bytes>
            <result_overflow_mode>break</result_overflow_mode>

            <!-- Row limits -->
            <max_rows_to_read>0</max_rows_to_read>
            <max_bytes_to_read>0</max_bytes_to_read>
            <read_overflow_mode>throw</read_overflow_mode>

            <!-- Network limits -->
            <max_network_bandwidth>0</max_network_bandwidth>
            <max_network_bytes>0</max_network_bytes>

            <!-- Misc settings -->
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>random</load_balancing>
            <allow_experimental_analyzer>1</allow_experimental_analyzer>
            <enable_optimize_predicate_expression>1</enable_optimize_predicate_expression>
            <optimize_move_to_prewhere>1</optimize_move_to_prewhere>
        </default>
    </profiles>
</clickhouse>
