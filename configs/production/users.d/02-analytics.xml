<?xml version="1.0"?>
<!-- MinervaDB Server: 02-analytics.xml - Analytics user profile with extended limits -->
<clickhouse>
    <profiles>
        <analytics>
            <max_memory_usage>32212254720</max_memory_usage>
            <max_threads>16</max_threads>
            <max_insert_threads>8</max_insert_threads>
            <max_execution_time>3600</max_execution_time>
            <max_rows_to_read>0</max_rows_to_read>
            <max_bytes_to_read>0</max_bytes_to_read>
            <max_result_rows>0</max_result_rows>
            <max_result_bytes>0</max_result_bytes>
            <result_overflow_mode>break</result_overflow_mode>
            <enable_http_compression>1</enable_http_compression>
            <allow_ddl>1</allow_ddl>
            <use_uncompressed_cache>1</use_uncompressed_cache>
            <allow_experimental_analyzer>1</allow_experimental_analyzer>
            <enable_optimize_predicate_expression>1</enable_optimize_predicate_expression>
        </analytics>
    </profiles>

    <users>
        <analyst>
            <password_sha256_hex>CHANGE_ME_SHA256_HASH</password_sha256_hex>
            <networks>
                <ip>::/0</ip>
            </networks>
            <profile>analytics</profile>
            <quota>default</quota>
        </analyst>
    </users>
</clickhouse>
