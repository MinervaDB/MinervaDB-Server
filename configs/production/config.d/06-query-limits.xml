<?xml version="1.0"?>
<!-- MinervaDB Server: 06-query-limits.xml - Query resource limits and timeouts -->
<clickhouse>
    <max_connections>4096</max_connections>
    <max_concurrent_queries>200</max_concurrent_queries>
    <max_concurrent_select_queries>100</max_concurrent_select_queries>
    <max_concurrent_insert_queries>50</max_concurrent_insert_queries>
    <uncompressed_cache_size>17179869184</uncompressed_cache_size>
    <mark_cache_size>5368709120</mark_cache_size>

    <!-- Query timeouts -->
    <max_execution_time>3600</max_execution_time>
    <max_query_size>10485760</max_query_size>
    <interactive_delay>100000</interactive_delay>
    <connect_timeout>10</connect_timeout>
    <connect_timeout_with_failover_ms>50</connect_timeout_with_failover_ms>
    <receive_timeout>300</receive_timeout>
    <send_timeout>300</send_timeout>
    <tcp_keep_alive_timeout>290</tcp_keep_alive_timeout>

    <!-- Async insert settings -->
    <async_insert_max_data_size>10485760</async_insert_max_data_size>
    <async_insert_busy_timeout_ms>200</async_insert_busy_timeout_ms>
    <async_insert_stale_timeout_ms>0</async_insert_stale_timeout_ms>

    <!-- Distributed DDL -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
        <cleanup_delay_period>60</cleanup_delay_period>
        <max_tasks_in_queue>1000</max_tasks_in_queue>
        <task_max_lifetime>604800</task_max_lifetime>
    </distributed_ddl>

    <!-- Query log -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <max_size_rows>1048576</max_size_rows>
        <reserved_size_rows>8192</reserved_size_rows>
        <flush_on_crash>false</flush_on_crash>
        <ttl>event_date + INTERVAL 30 DAY DELETE</ttl>
    </query_log>
</clickhouse>
